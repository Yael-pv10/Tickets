# =========================================
# Base de datos PostgreSQL
# =========================================
POSTGRES_DB=tickets
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_PORT=5432

# =========================================
# Backend Spring Boot
# =========================================
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080

# JWT (RS256). Generar con:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Luego pegar contenido en base64 o ruta del archivo.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRATION_MIN=15
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_ISSUER=auditorio-tickets

# Clave HMAC para firmar payload de los QR (256 bits, base64)
QR_SIGNING_SECRET=replace_with_a_strong_random_base64_secret

# OAuth2 Google
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
# Spring Security genera la ruta /login/oauth2/code/google por defecto.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# Admin bootstrap (se crea automáticamente al arrancar si no existe)
ADMIN_EMAIL=admin@auditorio.local
ADMIN_PASSWORD=ChangeMe123!

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (SMTP)
# MAIL_ENABLED=false desactiva el envío real (dev/CI sin servidor SMTP).
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@tudominio.com
MAIL_PASSWORD=app_password_here
MAIL_FROM=Auditorio Tickets <no-reply@tudominio.com>
# URL base del frontend, usada para los enlaces de los correos.
FRONTEND_BASE_URL=http://localhost:3000

# =========================================
# Frontend
# =========================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_random_secret
